<%- include('../partials/header') %><h1>Subscription Billing & Invoices</h1><div class="card"><form method="post"><select name="tenant_id"><% tenants.forEach(t=>{ %><option value="<%=t.id%>"><%=t.name%></option><% }) %></select><input name="amount" type="number" placeholder="Amount"><input name="due_date" type="date"><input name="notes" placeholder="Notes"><button>Generate Invoice</button></form></div><table><tr><th>Invoice</th><th>Client</th><th>Amount</th><th>Status</th><th>Date</th></tr><% invoices.forEach(i=>{ %><tr><td><%=i.invoice_no%></td><td><%=i.tenant_name%></td><td><%=i.amount%></td><td><%=i.status%></td><td><%=i.invoice_date%></td></tr><% }) %></table><%- include('../partials/footer') %>
