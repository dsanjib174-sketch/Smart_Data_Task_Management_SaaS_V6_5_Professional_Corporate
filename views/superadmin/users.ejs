<%- include('../partials/header') %><h1>User Creation</h1><div class="card"><form method="post"><select name="tenant_id"><option value="">Smart Data / Global</option><% tenants.forEach(t=>{ %><option value="<%=t.id%>"><%=t.name%></option><% }) %></select><input name="name" placeholder="Name" required><input name="email" placeholder="Email" required><input name="password" placeholder="Password" required><select name="role"><option>SD_ADMIN</option><option>SD_SUPPORT</option><option>SD_DEVELOPER</option><option>SD_ACCOUNTS</option><option>CLIENT_ADMIN</option><option>MANAGER</option><option>EMPLOYEE</option><option>VIEWER</option></select><input name="department" placeholder="Department"><button>Create User</button></form></div><table><tr><th>Name</th><th>Email</th><th>Role</th><th>Client</th></tr><% users.forEach(u=>{ %><tr><td><%=u.name%></td><td><%=u.email%></td><td><%=u.role%></td><td><%=u.tenant_name||'Global'%></td></tr><% }) %></table><%- include('../partials/footer') %>
