<%- include('../partials/header') %><h1>Subscription Plans</h1><div class="card"><form method="post"><input name="name" placeholder="Plan Name"><input name="price" type="number" placeholder="Price"><input name="user_limit" type="number" placeholder="Users"><input name="task_limit" type="number" placeholder="Tasks"><input name="features" placeholder="Features"><button>Save Plan</button></form></div><table><tr><th>Plan</th><th>Price</th><th>Users</th><th>Tasks</th><th>Features</th></tr><% plans.forEach(p=>{ %><tr><td><%=p.name%></td><td><%=p.price%></td><td><%=p.user_limit%></td><td><%=p.task_limit%></td><td><%=p.features%></td></tr><% }) %></table><%- include('../partials/footer') %>
