<%- include('../partials/header') %><h1>Advanced Task Management</h1><div class="card"><form method="post"><input name="title" placeholder="Task Subject" required><textarea name="description" placeholder="Description"></textarea><input name="department" placeholder="Department"><input name="location" placeholder="Location"><input name="category" placeholder="Category"><select name="priority"><option>Low</option><option selected>Medium</option><option>High</option><option>Critical</option></select><select name="assigned_to"><option value="">Assign To</option><% users.forEach(u=>{ %><option value="<%=u.id%>"><%=u.name%></option><% }) %></select><input type="datetime-local" name="due_at"><button>Create Task</button></form></div><table><tr><th>No</th><th>Title</th><th>Department</th><th>Priority</th><th>Status</th><th>Assigned</th><th>Action</th></tr><% tasks.forEach(t=>{ %><tr><td><%=t.task_no%></td><td><%=t.title%></td><td><%=t.department%></td><td><%=t.priority%></td><td><%=t.status%></td><td><%=t.assigned_name||'-'%></td><td><a href="/tasks/<%=t.id%>">Open</a></td></tr><% }) %></table><%- include('../partials/footer') %>
