<%- include('../partials/header') %><h1><%=task.task_no%> - <%=task.title%></h1><div class="card"><p><%=task.description%></p><p><b>Status:</b> <%=task.status%> | <b>Priority:</b> <%=task.priority%></p><form method="post" action="/tasks/<%=task.id%>/status"><select name="status"><option>Open</option><option>Assigned</option><option>Accepted</option><option>In Progress</option><option>Waiting Approval</option><option>Completed</option><option>Closed</option></select><button>Update Status</button></form></div><div class="grid"><div class="card"><h3>Comments</h3><form method="post" action="/tasks/<%=task.id%>/comments"><textarea name="comment" placeholder="Add comment" required></textarea><button>Add Comment</button></form><% comments.slice(0,5).forEach(c=>{ %><div class="comment"><b><%=c.name%></b><p><%=c.comment%></p><small><%=c.created_at%></small></div><% }) %></div><div class="card"><h3>Attachments</h3><form method="post" enctype="multipart/form-data" action="/tasks/<%=task.id%>/attachments"><input type="file" name="file"><button>Upload</button></form><% attachments.forEach(a=>{ %><p><a href="<%=a.file_path%>" target="_blank"><%=a.file_name%></a></p><% }) %></div></div><%- include('../partials/footer') %>
