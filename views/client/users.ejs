<%- include('../partials/header') %><h1>Client User Creation</h1><div class="card"><form method="post"><input name="name" placeholder="Name"><input name="email" placeholder="Email"><input name="password" placeholder="Password"><select name="role"><option>CLIENT_ADMIN</option><option>DEPARTMENT_HEAD</option><option>MANAGER</option><option>EMPLOYEE</option><option>VIEWER</option></select><input name="department" placeholder="Department"><button>Create User</button></form></div><table><tr><th>Name</th><th>Email</th><th>Role</th><th>Department</th></tr><% users.forEach(u=>{ %><tr><td><%=u.name%></td><td><%=u.email%></td><td><%=u.role%></td><td><%=u.department%></td></tr><% }) %></table><%- include('../partials/footer') %>
